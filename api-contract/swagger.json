    "/api/v1/quiz-attempts/{attemptId}": {
      "get": {
        "tags": ["QuizAttempt"],
        "summary": "퀴즈 응시 상세 결과 조회",
        "description": "[호출 화면] 퀴즈 기록 > 상세 보기\n[권한 조건] 로그인 필수 (JWT Bearer 토큰)\n[특이 동작] 문항별 선택 답안, 정답, 정답 여부를 모두 반환한다. 본인 기록만 조회 가능.\n",
        "operationId": "getDetail",
        "parameters": [
          {
            "name": "attemptId",
            "in": "path",
            "description": "응시 기록 ID",
            "required": true,
            "schema": { "type": "integer", "format": "int64" },
            "example": 1
          }
        ],
        "responses": {
          "200": {
            "description": "상세 결과 조회 성공",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/ApiResponseQuizAttemptDetailResponse" }
              }
            }
          },
          "404": {
            "description": "응시 기록을 찾을 수 없음",
            "content": {
              "*/*": {
                "schema": { "$ref": "#/components/schemas/ApiResponseQuizAttemptDetailResponse" }
              }
            }
          },

# Application
NEXT_PUBLIC_APP_NAME=SSAC Frontend
# 로컬: http://localhost:3000 / 배포: https://<your-vercel-domain>.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
# 로컬: http://localhost:3000 / 배포: https://<your-vercel-domain>.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# API (mock — jsonplaceholder, 전 환경 동일)
NEXT_PUBLIC_API_BASE_URL=https://jsonplaceholder.typicode.com

# Backend URL (public: 카카오 OAuth 브라우저 네비게이션 등 클라이언트에서 직접 사용)
# 로컬: http://localhost:8080 / 배포: https://<your-app>.up.railway.app
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# Backend API base URL (server-only, used by BFF route handlers)
# 로컬: http://localhost:8080 / 배포: https://<your-app>.up.railway.app
API_BASE_URL=http://localhost:8080

# Swagger (로컬 개발용, 배포 시 불필요)
# SWAGGER_URL=http://<backend-host>:8080/api-docs/swagger.json

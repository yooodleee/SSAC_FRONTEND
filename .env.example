# Application
NEXT_PUBLIC_APP_NAME=SSAC Frontend
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API
NEXT_PUBLIC_API_BASE_URL=https://jsonplaceholder.typicode.com

# Backend URL (public: 카카오 OAuth 브라우저 네비게이션 등 클라이언트에서 직접 사용)

# .env.e2e.example — E2E 진단 환경 변수 템플릿
# 사용법: cp .env.e2e.example .env.e2e 후 실제 값을 채우세요.
# .env.e2e 는 gitignore 대상입니다. 절대 커밋하지 마세요.

# 진단 대상 FE URL (기본값: https://ssac.io)
E2E_TARGET_URL=https://ssac.io

# 진단 대상 API URL
E2E_API_URL=https://api.ssac.io

# 실행할 시나리오: auth | api | all (기본값: all)
E2E_SCENARIO=all

# 관리자 코드 (민감 정보 — 팀 내부 공유)
E2E_ADMIN_CODE=xxxxxxxxxx

{
  "name": "ssac-frontend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/check-loading-gif.js",
    "build": "next build",
    "start": "next start",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "layers": "depcruise src --config .dependency-cruiser.cjs",
    "validate": "npm run typecheck && npm run lint && npm run format:check && npm run layers && npm run build",
    "validate:fix": "npm run lint:fix && npm run format",
    "validate:staged": "lint-staged",
    "scaffold": "node scripts/scaffold.js",
    "prepare": "husky",
    "sync:api": "bash scripts/sync-api.sh",
    "sync:api:local": "SWAGGER_URL=http://$(ip route show default | awk '{print $3}'):8080/api-docs/swagger.json bash scripts/sync-api.sh",
    "validate:error-mapping": "node --experimental-strip-types --no-warnings scripts/validateErrorMapping.ts",
    "lint:type-contract": "node scripts/lintTypeContract.mjs",
    "logs:vercel": "bash scripts/check-vercel-logs.sh",
    "logs:vercel:live": "vercel logs --follow",
    "pre-deploy": "bash scripts/pre-deploy-check.sh",
    "e2e:diagnose": "tsx scripts/e2e-diagnose/runner.ts",
    "e2e:diagnose:auth": "E2E_SCENARIO=auth tsx scripts/e2e-diagnose/runner.ts",
    "e2e:diagnose:api": "E2E_SCENARIO=api tsx scripts/e2e-diagnose/runner.ts"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@tiptap/extension-image": "^3.23.6",
    "@tiptap/extension-link": "^3.23.6",
    "@tiptap/extension-task-item": "^3.23.6",
    "@tiptap/extension-task-list": "^3.23.6",
    "@tiptap/react": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "next": "^16.2.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dependency-cruiser": "^16",
    "eslint": "^9",
    "eslint-config-next": "^16.2.4",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "lint-staged": "^16.4.0",
    "msw": "^2.14.6",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.5.3",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}

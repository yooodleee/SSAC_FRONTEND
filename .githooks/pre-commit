#!/bin/sh
# .githooks/pre-commit
#
# 커밋 전 자동 실행됩니다. 에이전트도 인간도 이 단계를 건너뛸 수 없습니다.
# 활성화: npm install (prepare 스크립트가 git config core.hooksPath .githooks 실행)

echo "🔍 Pre-commit validation..."

node --run validate

EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
  echo ""
  echo "❌ Commit blocked. Validation failed."
  echo ""
  echo "Fix the errors above, then commit again."
  echo "For diagnosis, run: npm run validate"
  exit 1
fi

echo "✅ Validation passed. Proceeding with commit."
